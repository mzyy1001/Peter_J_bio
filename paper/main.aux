\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Partial Correlation Network Reveals Direct Relationships}{8}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Partial correlation network.} Edges represent conditional associations estimated by Graphical Lasso, controlling for all other hallmarks. Sparsity (14/36 edges retained) indicates that many marginal correlations are mediated through intermediate hallmarks, though this interpretation is model-dependent.\relax }}{8}{figure.caption.6}\protected@file@percent }
\newlabel{fig:partial_network}{{3}{8}{\textbf {Partial correlation network.} Edges represent conditional associations estimated by Graphical Lasso, controlling for all other hallmarks. Sparsity (14/36 edges retained) indicates that many marginal correlations are mediated through intermediate hallmarks, though this interpretation is model-dependent.\relax }{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Conditional-Dependence Orientation}{9}{subsection.3.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Conditional-dependence orientation (PC algorithm approximation).} Red directed edges indicate oriented conditional associations under causal sufficiency and faithfulness assumptions. Gray dashed edges remain unoriented. This is an exploratory analysis; orientations should not be interpreted as validated causal relationships.\relax }}{9}{figure.caption.7}\protected@file@percent }
\newlabel{fig:causal}{{4}{9}{\textbf {Conditional-dependence orientation (PC algorithm approximation).} Red directed edges indicate oriented conditional associations under causal sufficiency and faithfulness assumptions. Gray dashed edges remain unoriented. This is an exploratory analysis; orientations should not be interpreted as validated causal relationships.\relax }{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Machine Learning: Age Group Classification}{9}{subsection.3.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Hallmark feature importance for age group classification.} Random Forest and Gradient Boosting importances. Integrative hallmarks (SCE, AIC) and Cellular Senescence dominate age-group discrimination.\relax }}{10}{figure.caption.8}\protected@file@percent }
\newlabel{fig:importance}{{5}{10}{\textbf {Hallmark feature importance for age group classification.} Random Forest and Gradient Boosting importances. Integrative hallmarks (SCE, AIC) and Cellular Senescence dominate age-group discrimination.\relax }{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.7}Chronological Age Prediction}{10}{subsection.3.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Age prediction from hallmark scores.} (Left) Cross-validated predicted vs.\ chronological age from Gradient Boosting model. (Right) Distribution of age-prediction residuals (predicted $-$ actual). In this simulation, residuals reflect model error, not biological age acceleration.\relax }}{10}{figure.caption.9}\protected@file@percent }
\newlabel{fig:bioage}{{6}{10}{\textbf {Age prediction from hallmark scores.} (Left) Cross-validated predicted vs.\ chronological age from Gradient Boosting model. (Right) Distribution of age-prediction residuals (predicted $-$ actual). In this simulation, residuals reflect model error, not biological age acceleration.\relax }{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.8}Cross-Hallmark Predictability}{10}{subsection.3.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Cross-hallmark predictability.} For each hallmark, a Random Forest model predicts its score from all other hallmarks (5-fold CV). Higher $R^2$ indicates greater predictability from other hallmark scores.\relax }}{11}{figure.caption.10}\protected@file@percent }
\newlabel{fig:cross_pred}{{7}{11}{\textbf {Cross-hallmark predictability.} For each hallmark, a Random Forest model predicts its score from all other hallmarks (5-fold CV). Higher $R^2$ indicates greater predictability from other hallmark scores.\relax }{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.9}Dimensionality Reduction of Hallmark Space}{11}{subsection.3.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {PCA of hallmark activity scores.} (Left) Colored by chronological age; (Right) colored by tissue type. PC1 captures age-related variation, PC2 captures tissue heterogeneity.\relax }}{11}{figure.caption.11}\protected@file@percent }
\newlabel{fig:pca}{{8}{11}{\textbf {PCA of hallmark activity scores.} (Left) Colored by chronological age; (Right) colored by tissue type. PC1 captures age-related variation, PC2 captures tissue heterogeneity.\relax }{figure.caption.11}{}}
