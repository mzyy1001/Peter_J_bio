\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Hallmark activity score correlation matrix.} Spearman correlations between ssGSEA-derived hallmark scores across 300 samples. Stars indicate significance levels (unadjusted $p$-values): $*p<0.05$, $**p<0.01$, $***p<0.001$.\relax }}{6}{figure.caption.3}\protected@file@percent }
\newlabel{fig:corr_heatmap}{{1}{6}{\textbf {Hallmark activity score correlation matrix.} Spearman correlations between ssGSEA-derived hallmark scores across 300 samples. Stars indicate significance levels (unadjusted $p$-values): $*p<0.05$, $**p<0.01$, $***p<0.001$.\relax }{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Hallmark correlation network.} Nodes represent hallmarks colored by hierarchical category (red: primary, orange: antagonistic, blue: integrative). Edge thickness reflects correlation strength. Node size reflects eigenvector centrality.\relax }}{7}{figure.caption.4}\protected@file@percent }
\newlabel{fig:corr_network}{{2}{7}{\textbf {Hallmark correlation network.} Nodes represent hallmarks colored by hierarchical category (red: primary, orange: antagonistic, blue: integrative). Edge thickness reflects correlation strength. Node size reflects eigenvector centrality.\relax }{figure.caption.4}{}}
