\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Ground-truth benchmarking results. Target: \textbf  {observed latent hallmark correlations} (after age and tissue effects, before gene-level noise/scoring). True edges: pairs with $|\rho _{\text  {observed}}| > 0.1$. Ground-truth modules: Primary (GI, TA, EA, LP), Antagonistic (DNS, MD, CS), Integrative (SCE, AIC). Note: the simulation uses random signed gene loadings that the unsigned scoring cannot fully recover, deliberately stress-testing the pipeline.\relax }}{13}{table.caption.13}\protected@file@percent }
\newlabel{tab:benchmarks}{{4}{13}{Ground-truth benchmarking results. Target: \textbf {observed latent hallmark correlations} (after age and tissue effects, before gene-level noise/scoring). True edges: pairs with $|\rho _{\text {observed}}| > 0.1$. Ground-truth modules: Primary (GI, TA, EA, LP), Antagonistic (DNS, MD, CS), Integrative (SCE, AIC). Note: the simulation uses random signed gene loadings that the unsigned scoring cannot fully recover, deliberately stress-testing the pipeline.\relax }{table.caption.13}{}}
